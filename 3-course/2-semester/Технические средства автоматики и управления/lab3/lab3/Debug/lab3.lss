  b2:	80 6b       	ori	r24, 0xB0	; 176
  b4:	84 bd       	out	0x24, r24	; 36
        1    0    0  | 256        (62.5 кГц)
        1    0    1  | 1024       (15.625 кГц)
        1    1    0  | Внешний такт на пине T0 
        1    1    1  | Внешний такт на пине T0
    */
    TCCR0B |= (0 << CS02) | (1 << CS01) | (1 << CS00);
